VITE_API_BASE_URL=
# Must match a value in API_CLIENT_KEYS on the API when key enforcement is enabled.
# Exposed as window.AFTERCARE_CONFIG.apiKey for aftercare-text-widget / badge poll embeds.
VITE_API_KEY=
# Firebase RTDB URL (same as FIREBASE_DB_URL on the API) — must be a firebaseio.com /
# firebasedatabase.app URL, NOT the API base URL. Injected into the widget on build.
FIREBASE_DB_URL=
